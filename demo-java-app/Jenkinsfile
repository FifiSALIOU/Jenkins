// Jenkinsfile — Pipeline DevSecOps : Contrôle, Qualité, Sécurité
// Version simplifiée (sans Docker agent)
//
pipeline {
    agent any

    tools {
        maven 'Maven-3.9'
    }

    environment {
        APP_NAME    = 'myapp'
        DOCKER_REG  = 'registry:5000'
        DOCKER_IMG  = "${APP_NAME}:${BUILD_NUMBER}"
        SONAR_URL   = 'http://sonarqube:9000'
    }

    triggers {
        pollSCM('H/5 * * * *')
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        // === CONTRÔLE ===
        stage('Contrôle - Checkout') {
            steps {
                checkout scm
                sh 'echo "Branch: ${GIT_BRANCH}, Commit: ${GIT_COMMIT}"'
            }
        }

        stage('Contrôle - Build') {
            steps {
                dir('demo-java-app') {
                    sh 'mvn clean package -DskipTests -q'
                    archiveArtifacts artifacts: 'target/*.jar'
                }
            }
        }

        // === QUALITÉ ===
        stage('Qualité - Tests') {
            steps {
                dir('demo-java-app') {
                    sh 'mvn test'
                }
            }
        }

        // === QUALITÉ - SonarQube ===
        stage('Qualité - Analyse SonarQube') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    dir('demo-java-app') {
                        sh 'mvn sonar:sonar -Dsonar.projectKey=${APP_NAME} -Dsonar.host.url=${SONAR_URL}'
                    }
                }
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        // === SÉCURITÉ : scan des vulnérabilités dans les dépendances (pom.xml) ===
        stage('Sécurité - Analyse dépendances') {
            steps {
                dir('demo-java-app') {
                    sh 'mvn org.owasp:dependency-check-maven:check -DfailOnError=false -Dformat=HTML -q'
                }
            }
        }

        // === SÉCURITÉ : scan de l'image Docker (dans un setup complet) ===
        stage('Sécurité - Scan image Docker') {
            steps {
                sh '''
                  echo "=== Scan de sécurité des images Docker ==="
                  echo "Dans un pipeline complet : après 'docker build', on exécuterait :"
                  echo "  trivy image --severity HIGH,CRITICAL mon-image:tag"
                  echo "  ou : docker scout cves mon-image:tag"
                  echo "Ici : pas de build Docker (agent any), cette étape documente le processus."
                '''
            }
        }
    }

    post {
        success {
            echo "Pipeline DevSecOps réussi pour ${APP_NAME}, build #${BUILD_NUMBER}"
        }
        failure {
            echo "Échec du pipeline DevSecOps sur l’étape : ${STAGE_NAME}"
        }
        always {
            deleteDir()
        }
    }
}
