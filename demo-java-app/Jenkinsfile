// Jenkinsfile — Pipeline DevSecOps : Contrôle, Qualité, Sécurité
// Version simplifiée (sans Docker agent)
//
pipeline {
    agent any

    tools {
        maven 'Maven-3.9'
    }

    environment {
        APP_NAME    = 'myapp'
        DOCKER_REG  = 'registry:5000'
        DOCKER_IMG  = "${APP_NAME}:${BUILD_NUMBER}"
        SONAR_URL   = 'http://sonarqube:9000'
    }

    triggers {
        pollSCM('H/5 * * * *')
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        // === CONTRÔLE ===
        stage('Contrôle - Checkout') {
            steps {
                checkout scm
                sh 'echo "Branch: ${GIT_BRANCH}, Commit: ${GIT_COMMIT}"'
            }
        }

        stage('Contrôle - Build') {
            steps {
                dir('demo-java-app') {
                    sh 'mvn clean package -DskipTests -q'
                    archiveArtifacts artifacts: 'target/*.jar'
                }
            }
        }

        // === QUALITÉ ===
        stage('Qualité - Tests') {
            steps {
                dir('demo-java-app') {
                    sh 'mvn test'
                }
            }
        }

        // === QUALITÉ - SonarQube (optionnel) ===
        stage('Qualité - Analyse SonarQube') {
            when {
                expression { return false }
            }
            steps {
                withSonarQubeEnv('SonarQube') {
                    dir('demo-java-app') {
                        sh 'mvn sonar:sonar -Dsonar.projectKey=${APP_NAME}'
                    }
                }
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // === SÉCURITÉ ===
        stage('Sécurité - Analyse dépendances') {
            steps {
                sh 'echo "== Analyse de sécurité des dépendances (OWASP Dependency-Check) =="'
            }
        }

        stage('Sécurité - Scan image Docker') {
            steps {
                sh 'echo "== Scan image Docker (Trivy, Docker Scout) =="'
            }
        }
    }

    post {
        success {
            echo "Pipeline DevSecOps réussi pour ${APP_NAME}, build #${BUILD_NUMBER}"
        }
        failure {
            echo "Échec du pipeline DevSecOps sur l’étape : ${STAGE_NAME}"
        }
        always {
            deleteDir()
        }
    }
}
