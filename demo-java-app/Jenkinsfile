// Jenkinsfile — Pipeline DevSecOps : Contrôle, Qualité, Sécurité
// À placer à la racine du dépôt Git
//
pipeline {
    agent {
        docker { image 'maven:3.9-eclipse-temurin-17' }
    }

    environment {
        APP_NAME    = 'myapp'
        // Registry local défini dans docker-compose.yml
        DOCKER_REG  = 'registry:5000'
        DOCKER_IMG  = "${APP_NAME}:${BUILD_NUMBER}"
        SONAR_URL   = 'http://sonarqube:9000'
    }

    triggers {
        githubPush()  // Déclenchement automatique sur push
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        // === CONTRÔLE : maîtrise du code et du build ===
        stage('Contrôle - Checkout') {
            steps {
                checkout scm
                sh 'echo "Branch: ${GIT_BRANCH}, Commit: ${GIT_COMMIT}"'
            }
        }

        stage('Contrôle - Build') {
            steps {
                sh 'mvn clean package -DskipTests -q'
                archiveArtifacts artifacts: 'target/*.jar'
            }
        }

        // === QUALITÉ : tests automatiques ===
        stage('Qualité - Tests') {
            parallel {
                stage('Tests unitaires') {
                    steps {
                        sh 'mvn test'
                        junit 'target/surefire-reports/*.xml'
                    }
                }
                stage('Tests d’intégration') {
                    steps {
                        sh 'mvn verify -P integration-tests'
                    }
                }
            }
        }

        // === QUALITÉ : analyse SonarQube ===
        stage('Qualité - Analyse SonarQube') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh 'mvn sonar:sonar -Dsonar.projectKey=${APP_NAME}'
                }
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // === SÉCURITÉ : analyse des dépendances (SAST) ===
        stage('Sécurité - Analyse dépendances') {
            steps {
                sh '''
                  echo "== Analyse de sécurité des dépendances (ex: OWASP Dependency-Check) =="
                  # Exemple si le plugin Maven est configuré :
                  # mvn org.owasp:dependency-check-maven:check -Dformat=HTML -DoutputDirectory=target/dependency-check
                '''
            }
        }

        // === CONTRÔLE / DÉPLOIEMENT : image Docker versionnée ===
        stage('Contrôle - Docker Build & Push') {
            steps {
                script {
                    def img = docker.build("${DOCKER_REG}/${DOCKER_IMG}")
                    docker.withRegistry("http://${DOCKER_REG}", 'docker-registry-creds') {
                        img.push()
                        img.push('latest')
                    }
                }
            }
        }

        // === SÉCURITÉ : scan de l’image (Container Security) ===
        stage('Sécurité - Scan image Docker') {
            steps {
                sh '''
                  echo "== Scan de l’image Docker (ex: Trivy, Docker Scout, etc.) =="
                  echo "Image scannée : ${DOCKER_REG}/${DOCKER_IMG}"
                  # Exemple de commande si Trivy est installé :
                  # trivy image --severity HIGH,CRITICAL ${DOCKER_REG}/${DOCKER_IMG}
                '''
            }
        }
    }

    post {
        success {
            echo "Pipeline DevSecOps réussi pour ${APP_NAME}, build #${BUILD_NUMBER}"
        }
        failure {
            echo "Échec du pipeline DevSecOps sur l’étape : ${STAGE_NAME}"
        }
        always {
            cleanWs()  // Nettoie le workspace après chaque build
        }
    }
}

